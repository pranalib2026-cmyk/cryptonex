# ═══════════════════════════════════════════════════
# CryptoNex — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── MongoDB (document store — prices, news, analysis cache) ─
MONGODB_URI=mongodb://mongo:27017/cryptonex

# ─── PostgreSQL (relational — portfolio, users, alerts) ──
POSTGRES_DB=cryptonex
POSTGRES_USER=cryptonex
POSTGRES_PASSWORD=s3OkWwnuAP$rJL5=2vhZ-@bd
POSTGRES_URL=postgresql://cryptonex:s3OkWwnuAP$rJL5=2vhZ-@bd@postgres:5432/cryptonex

# ─── Redis Cache ──────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Service URLs (Docker internal) ──────────────
FRONTEND_URL=http://frontend:3000
ANALYSIS_ENGINE_URL=http://analysis:8000

# ─── Nginx Ports ──────────────────────────────────
NGINX_PORT=80
NGINX_SSL_PORT=443

# ─── External API Keys ────────────────────────────
# CoinGecko — free tier works without a key, but higher rate limits w/ key
# Get at: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# CryptoPanic — required for news feed with sentiment
# Get free key at: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# Whale Alert — BTC whale transaction monitoring
# Get free key at: https://whale-alert.io/
WHALE_ALERT_API_KEY=

# Alpha Vantage — Stock market data (Nifty, Sensex via equity endpoint)
# Get free key at: https://www.alphavantage.co/support/
ALPHA_VANTAGE_API_KEY=

# ─── Security ─────────────────────────────────────
# Max requests per window, per IP
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# JWT secret (if auth is added in future)
# JWT_SECRET=change_me_in_production_min_32_chars

# ─── Deployment (set as GitHub Actions repository secrets) ─
# VPS_HOST=your-server-ip-or-domain.com
# VPS_USER=deploy
# VPS_SSH_KEY=<paste private key contents>
