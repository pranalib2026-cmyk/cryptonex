# ══════════════════════════════════════════
# CryptoNex Backend — Environment Variables
# ══════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/cryptonex

# Redis (optional — falls back to in-memory cache)
REDIS_URL=

# API Keys (optional — mock data used when missing)
COINGECKO_API_KEY=
CRYPTOPANIC_API_KEY=
WHALE_ALERT_API_KEY=
ALPHA_VANTAGE_API_KEY=

# CORS
FRONTEND_URL=http://localhost:8080

# Cache TTL (seconds)
CACHE_TTL_PRICES=5
CACHE_TTL_NEWS=300
CACHE_TTL_SENTIMENT=60
CACHE_TTL_INDICATORS=10
